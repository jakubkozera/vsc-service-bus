          "group": "2_io@1"
        },
        {
          "command": "serviceBusExplorer.queue.rename",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == queue",
          "group": "9_modify@1"
        },
        {
          "command": "serviceBusExplorer.queue.delete",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == queue",
          "group": "9_modify@2"
        },
        {
          "command": "serviceBusExplorer.listener.start",
