          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "serviceBusExplorer.addNamespace",
          "when": "view == serviceBusExplorer.namespacesView",
          "group": "navigation@1"
        },
        {
          "command": "serviceBusExplorer.tree.filter",
          "when": "view == serviceBusExplorer.namespacesView",
          "group": "navigation@2"
        },
        {
          "command": "serviceBusExplorer.refreshTree",
          "when": "view == serviceBusExplorer.namespacesView",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "serviceBusExplorer.testConnection",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == namespace",
          "group": "1_actions@1"
        },
        {
          "command": "serviceBusExplorer.dashboard.open",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == namespace",
          "group": "1_actions@2"
        },
        {
          "command": "serviceBusExplorer.namespace.export",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == namespace",
          "group": "2_io@1"
        },
        {
          "command": "serviceBusExplorer.namespace.import",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == namespace",
          "group": "2_io@2"
        },
        {
          "command": "serviceBusExplorer.legacyXml.import",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == namespace",
          "group": "2_io@3"
        },
        {
          "command": "serviceBusExplorer.editNamespace",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == namespace",
          "group": "9_modify@1"
        },
        {
          "command": "serviceBusExplorer.removeNamespace",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == namespace",
          "group": "9_modify@2"
        },
        {
          "command": "serviceBusExplorer.refreshNode",
          "when": "view == serviceBusExplorer.namespacesView",
          "group": "z_refresh",
          "icon": "$(refresh)"
        },
        {
          "command": "serviceBusExplorer.queue.create",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == queuesFolder",
          "group": "1_modify@1",
          "icon": "$(add)"
        },
        {
          "command": "serviceBusExplorer.queue.create",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == queuesFolder",
          "group": "inline@1",
          "icon": "$(add)"
        },
        {
          "command": "serviceBusExplorer.queue.edit",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == queue",
          "group": "1_modify@1"
        },
        {
          "command": "serviceBusExplorer.queue.send",
