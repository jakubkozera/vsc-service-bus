          "group": "2_io@1"
        },
        {
          "command": "serviceBusExplorer.topic.rename",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == topic",
          "group": "9_modify@1"
        },
        {
          "command": "serviceBusExplorer.topic.delete",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == topic",
          "group": "9_modify@2"
        },
        {
          "command": "serviceBusExplorer.testSender.open",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == topic",
          "group": "8_advanced@1"
        },
        {
          "command": "serviceBusExplorer.subscription.edit",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == subscription",
          "group": "1_modify@1"
        },
        {
          "command": "serviceBusExplorer.messages.view",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == subscription",
          "group": "1_modify@2"
        },
        {
          "command": "serviceBusExplorer.rule.create",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == subscription",
          "group": "1_modify@3"
        },
        {
          "command": "serviceBusExplorer.subscription.purge",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == subscription",
          "group": "8_advanced@1"
        },
        {
          "command": "serviceBusExplorer.subscription.delete",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == subscription",
          "group": "9_modify@1"
        },
        {
          "command": "serviceBusExplorer.listener.start",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == subscription",
          "group": "8_advanced@2"
        },
        {
          "command": "serviceBusExplorer.rule.edit",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == rule",
          "group": "1_modify@1"
        },
        {
          "command": "serviceBusExplorer.rule.delete",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == rule",
          "group": "9_modify@1"
        },
        {
          "command": "serviceBusExplorer.messages.viewDeadLetter",
          "when": "view == serviceBusExplorer.namespacesView && viewItem =~ /deadLetter|transferDeadLetter/",
          "group": "1_modify@1"
        },
        {
          "command": "serviceBusExplorer.copyName",
          "when": "view == serviceBusExplorer.namespacesView && viewItem =~ /queue|topic|subscription|rule|namespace/",
          "group": "z_copy"
        },
        {
          "command": "serviceBusExplorer.batch.delete",
          "when": "view == serviceBusExplorer.namespacesView && viewItem =~ /queue|topic|subscription/",
          "group": "z_batch@1"
        },
        {
          "command": "serviceBusExplorer.batch.disable",
          "when": "view == serviceBusExplorer.namespacesView && viewItem =~ /queue|topic|subscription/",
          "group": "z_batch@2"
        },
        {
          "command": "serviceBusExplorer.batch.enable",
          "when": "view == serviceBusExplorer.namespacesView && viewItem =~ /queue|topic|subscription/",
          "group": "z_batch@3"
        },
        {
          "command": "serviceBusExplorer.batch.export",
          "when": "view == serviceBusExplorer.namespacesView && viewItem =~ /queue|topic|subscription/",
          "group": "z_batch@4"
        }
      ]
    },
    "configuration": {
      "title": "Service Bus Explorer",
      "properties": {
        "serviceBusExplorer.peekDefaultCount": {
          "type": "number",
          "default": 50,
          "description": "Default number of messages to peek."
        },
        "serviceBusExplorer.receiveDefaultTimeoutMs": {
          "type": "number",
          "default": 5000,
          "description": "Default receive timeout in milliseconds."
        },
        "serviceBusExplorer.maxLockRenewMinutes": {
          "type": "number",
          "default": 5,
          "description": "Maximum lock renew duration in minutes."
        },
        "serviceBusExplorer.dashboard.refreshIntervalSeconds": {
          "type": "number",
          "default": 15,
          "description": "Dashboard auto-refresh interval in seconds."
        },
        "serviceBusExplorer.dashboard.dlqWarnThreshold": {
          "type": "number",
          "default": 1,
          "description": "Highlight rows when DLQ count is at or above this threshold."
        },
        "serviceBusExplorer.tree.alwaysShowDLQ": {
          "type": "boolean",
          "default": true,
          "description": "Always show the dead-letter sub-queue node under each queue/subscription."
        },
        "serviceBusExplorer.dlq.deleteTimeoutMs": {
          "type": "number",
          "default": 30000
        },
        "serviceBusExplorer.dlq.deleteMaxAttempts": {
          "type": "number",
          "default": 5
        },
        "serviceBusExplorer.purge.batchSize": {
          "type": "number",
          "default": 100
        },
        "serviceBusExplorer.purge.timeoutMs": {
          "type": "number",
          "default": 60000
        },
        "serviceBusExplorer.listener.maxLogEntries": {
          "type": "number",
          "default": 10000
        },
        "serviceBusExplorer.testSender.maxConcurrency": {
          "type": "number",
          "default": 16
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run install:webviews && npm run build:webviews && npm run build:ext",
    "install:webviews": "npm --prefix webviews install --no-audit --no-fund",
    "build:ext": "node esbuild.config.js",
    "build:webviews": "npm --prefix webviews run build",
    "watch": "node esbuild.config.js --watch",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "@types/vscode": "^1.90.0",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@azure/identity": "^4.4.0",
    "@azure/service-bus": "^7.9.5",
    "uuid": "^9.0.1"
  }
}
