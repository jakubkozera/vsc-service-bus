          "command": "serviceBusExplorer.topic.create",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == topicsFolder",
          "group": "1_modify@1",
          "icon": "$(add)"
        },
        {
          "command": "serviceBusExplorer.topic.create",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == topicsFolder",
          "group": "inline@1",
          "icon": "$(add)"
        },
        {
          "command": "serviceBusExplorer.topic.edit",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == topic",
          "group": "1_modify@1"
        },
        {
          "command": "serviceBusExplorer.topic.send",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == topic",
          "group": "1_modify@2"
        },
        {
          "command": "serviceBusExplorer.subscription.create",
          "when": "view == serviceBusExplorer.namespacesView && viewItem == topic",
