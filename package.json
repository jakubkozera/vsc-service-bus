{
  "name": "service-bus-explorer",
  "displayName": "Service Bus Explorer",
  "description": "Manage Azure Service Bus namespaces, queues, topics, subscriptions, rules and messages from VS Code.",
  "version": "0.1.0",
  "publisher": "jakubkozera",
  "sponsor": {
    "url": "https://github.com/sponsors/jakubkozera"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jakubkozera/vsc-service-bus.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Azure"
  ],
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "activationEvents": [
    "onView:serviceBusExplorer.namespacesView"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "serviceBusExplorer",
          "title": "Service Bus Explorer",
          "icon": "media/namespace.svg"
        }
      ]
    },
    "views": {
      "serviceBusExplorer": [
        {
          "id": "serviceBusExplorer.namespacesView",
          "name": "Namespaces",
          "icon": "media/namespace.svg",
          "contextualTitle": "Service Bus Explorer"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "serviceBusExplorer.namespacesView",
        "contents": "No Service Bus namespaces have been added yet.\n[Add Namespace](command:serviceBusExplorer.addNamespace)\nYou can connect using a SAS connection string or Microsoft Entra ID."
      }
    ],
    "commands": [
      {
        "command": "serviceBusExplorer.addNamespace",
        "title": "Add Namespace",
        "category": "Service Bus",
        "icon": "$(add)"
      },
      {
        "command": "serviceBusExplorer.removeNamespace",
        "title": "Remove Namespace",
        "category": "Service Bus",
        "icon": "$(trash)"
      },
      {
        "command": "serviceBusExplorer.editNamespace",
        "title": "Edit Namespace",
        "category": "Service Bus",
        "icon": "$(edit)"
      },
      {
        "command": "serviceBusExplorer.testConnection",
        "title": "Test Connection",
        "category": "Service Bus",
        "icon": "$(plug)"
      },
      {
        "command": "serviceBusExplorer.refreshTree",
        "title": "Refresh",
        "category": "Service Bus",
        "icon": "$(refresh)"
      },
      {
        "command": "serviceBusExplorer.refreshNode",
        "title": "Refresh Node",
        "category": "Service Bus",
        "icon": "$(refresh)"
      },
      {
        "command": "serviceBusExplorer.copyName",
        "title": "Copy Name",
        "category": "Service Bus"
      },
      {
        "command": "serviceBusExplorer.queue.create",
        "title": "Create Queue",
        "category": "Service Bus",
        "icon": "$(add)"
      },
      {
        "command": "serviceBusExplorer.queue.open",
        "title": "Open Queue",
        "category": "Service Bus"
      },
      {
        "command": "serviceBusExplorer.queue.edit",
        "title": "Edit Queue",
        "category": "Service Bus",
        "icon": "$(edit)"
      },
      {
        "command": "serviceBusExplorer.queue.rename",
        "title": "Rename Queue",
        "category": "Service Bus",
        "icon": "$(edit)"
      },
      {
        "command": "serviceBusExplorer.queue.delete",
        "title": "Delete Queue",
        "category": "Service Bus",
        "icon": "$(trash)"
      },
      {
        "command": "serviceBusExplorer.queue.send",
        "title": "Send Message",
        "category": "Service Bus",
        "icon": "$(send)"
      },
      {
        "command": "serviceBusExplorer.queue.purge",
        "title": "Purge Messages",
        "category": "Service Bus"
      },
      {
        "command": "serviceBusExplorer.topic.create",
        "title": "Create Topic",
        "category": "Service Bus",
        "icon": "$(add)"
      },
      {
        "command": "serviceBusExplorer.topic.open",
        "title": "Open Topic",
        "category": "Service Bus"
      },
      {
        "command": "serviceBusExplorer.topic.edit",
        "title": "Edit Topic",
        "category": "Service Bus",
        "icon": "$(edit)"
      },
      {
        "command": "serviceBusExplorer.topic.rename",
        "title": "Rename Topic",
        "category": "Service Bus",
        "icon": "$(edit)"
      },
      {
        "command": "serviceBusExplorer.topic.delete",
        "title": "Delete Topic",
        "category": "Service Bus",
        "icon": "$(trash)"
      },
      {
        "command": "serviceBusExplorer.topic.send",
        "title": "Send Message",
        "category": "Service Bus",
        "icon": "$(send)"
      },
      {
        "command": "serviceBusExplorer.subscription.create",
        "title": "Create Subscription",
        "category": "Service Bus",
        "icon": "$(add)"
      },
      {
        "command": "serviceBusExplorer.subscription.open",
        "title": "Open Subscription",
        "category": "Service Bus"
      },
      {
        "command": "serviceBusExplorer.subscription.edit",
        "title": "Edit Subscription",
        "category": "Service Bus",
        "icon": "$(edit)"
      },
      {
        "command": "serviceBusExplorer.subscription.delete",
        "title": "Delete Subscription",
        "category": "Service Bus",
        "icon": "$(trash)"
      },
      {
        "command": "serviceBusExplorer.subscription.purge",
        "title": "Purge Messages",
        "category": "Service Bus"
      },
      {
        "command": "serviceBusExplorer.rule.create",
        "title": "Create Rule",
        "category": "Service Bus",
        "icon": "$(add)"
      },
      {
        "command": "serviceBusExplorer.rule.edit",
        "title": "Edit Rule",
        "category": "Service Bus",
        "icon": "$(edit)"
      },
      {
        "command": "serviceBusExplorer.rule.delete",
        "title": "Delete Rule",
        "category": "Service Bus",
        "icon": "$(trash)"
      },
      {
        "command": "serviceBusExplorer.messages.view",
        "title": "View Messages",
        "category": "Service Bus",
        "icon": "$(inbox)"
      },
      {
        "command": "serviceBusExplorer.messages.viewDeadLetter",
        "title": "View Dead-letter Messages",
        "category": "Service Bus"
      },
      {
        "command": "serviceBusExplorer.dashboard.open",
        "title": "Open Dashboard",
        "category": "Service Bus",
        "icon": "$(dashboard)"
      },
      {
        "command": "serviceBusExplorer.namespace.export",
        "title": "Export Namespace…",
        "category": "Service Bus"
      },
      {
        "command": "serviceBusExplorer.namespace.import",
        "title": "Import to Namespace…",
        "category": "Service Bus"
      },
      {
        "command": "serviceBusExplorer.entity.export",
        "title": "Export Entity…",
        "category": "Service Bus"
      },
      {
        "command": "serviceBusExplorer.listener.start",
        "title": "Start Listener",
        "category": "Service Bus"
      },
      {
        "command": "serviceBusExplorer.testSender.open",
        "title": "Send Test Messages…",
        "category": "Service Bus"
      },
      {
        "command": "serviceBusExplorer.legacyXml.import",
        "title": "Import from legacy XML…",
        "category": "Service Bus"
      },
      {
        "command": "serviceBusExplorer.tree.filter",
        "title": "Filter Tree…",
        "category": "Service Bus",
        "icon": "$(filter)"
      },
      {
        "command": "serviceBusExplorer.batch.delete",
        "title": "Delete Selected",
        "category": "Service Bus",
        "icon": "$(trash)"
      },
      {
        "command": "serviceBusExplorer.batch.disable",
        "title": "Disable Selected",
        "category": "Service Bus"
      },
      {
        "command": "serviceBusExplorer.batch.enable",
        "title": "Enable Selected",
        "category": "Service Bus"
      },
      {
        "command": "serviceBusExplorer.batch.export",
        "title": "Export Selected",
        "category": "Service Bus"
      },
      {
        "command": "serviceBusExplorer.focus",
        "title": "Focus on Service Bus Explorer",
        "category": "Service Bus",
        "icon": "media/namespace.svg"
      }
    ],
    "menus": {
